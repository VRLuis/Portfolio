---
const {
    companyLogo,
    experienceCompany,
    experienceDateStart,
    experienceDateEnd,
    experienceLocation
} = Astro.props;

const basePath = import.meta.env.BASE_URL || '/';
const normalizedBasePath = basePath.endsWith('/') ? basePath : `${basePath}/`;
const companyLogoSrc = companyLogo?.startsWith('http') || companyLogo?.startsWith('//')
    ? companyLogo
    : `${normalizedBasePath}${companyLogo}`;
---

<div>
    <div class="flex items-center gap-2 mb-2">
        <img src={companyLogoSrc} alt={experienceCompany} class="max-h-12 object-contain" />
        <h2 class="text-lg font-semibold">{ experienceCompany }</h2>
    </div>
    <div class="mt-2">
        <span class="text-sm text-secondary-text">{ experienceDateStart } - { experienceDateEnd }</span>
        <h3 class="text-md font-medium">{ experienceLocation }</h3>
    </div>
</div>