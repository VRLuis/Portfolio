---
const {
    certificateName, 
    certificateDescription, 
    certificateImage, 
    certificateLink,
    translations
} = Astro.props;
---

<div class="grid grid-cols-1 gap-4 md:grid-cols-[1fr_2fr] bg-card py-4 px-5 rounded-3xl shadow-lg shadow-secondary-accent">
    <div class="flex flex-col items-center justify-center gap-4">
        <h2 class="text-xl font-bold text-center md:text-left">{certificateName}</h2>
        <img src={certificateImage} alt={certificateName} class="w-2/3 md:w-full mt-2 rounded-lg shadow-md" />
    </div>

    <div class="flex flex-col justify-center gap-3">
        <p class="text-base md:text-xl">{certificateDescription}</p>
        <a href={certificateLink} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline text-lg">{translations.buttons.viewCertificate}</a>
    </div>
</div>