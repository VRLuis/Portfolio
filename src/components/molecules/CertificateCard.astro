---
const {
    certificateName, 
    certificateDescription, 
    certificateImage, 
    certificateLink 
} = Astro.props;
---

<div class="grid grid-cols-3 bg-card py-2 px-5">
    <div class="col-span-1 flex flex-col items-center justify-center">
        <h2 class="text-xl font-bold">{certificateName}</h2>
        <img src={certificateImage} alt={certificateName} class="w-2/3 mt-2 rounded-lg shadow-md" />
    </div>

    <div class="col-span-2 items-center justify-center flex flex-col gap-2">
        <p class="text-xl">{certificateDescription}</p>
        <a href={certificateLink} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline text-lg">View Certificate</a>
    </div>
</div>