---
const { 
    centerName,
    formationName,
    startDate,
    endDate,
    formationLocation
} = Astro.props;
---

<div class="w-4/5 bg-card p-5">
    <h1 class="text-xl text-center font-bold mb-5">{ formationName }</h1>
    <h2 class="text-lg font-semibold">{ centerName }</h2>
    
    <span class="text-sm text-secondary-text">{ startDate } - { endDate }</span>
    <h3 class="text-md font-medium">{ formationLocation }</h3>
</div>