---
const { 
    learningName,
    learningDescription,
    learningIcon
} = Astro.props;

const basePath = import.meta.env.BASE_URL || '/';
const learningIconSrc = learningIcon?.startsWith('http') || learningIcon?.startsWith('//')
    ? learningIcon
    : `${basePath}${learningIcon}`;
---

<div class="w-full bg-card p-5 rounded-lg shadow-lg hover:shadow-xl transition-all shadow-secondary-accent">
    <h1 class="text-xl text-center font-bold mb-5">{ learningName }</h1>
    <h2 class="text-lg font-semibold text-secondary-text">{ learningDescription }</h2>
    
    <img src={ learningIconSrc } alt={ learningName } class="w-20 mx-auto mt-5"/>
</div>