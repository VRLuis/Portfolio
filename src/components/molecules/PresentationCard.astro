---
import { Image } from 'astro:assets';
import portfolioImage from '../../assets/fotocurriculum.jpg';
import SocialMediaLink from '../atoms/SocialMediaLink.astro';
import EmailButton from '../atoms/EmailButton.astro';
const { contact, translations } = Astro.props;
---

<div class="mx-auto w-full max-w-4xl grid gap-6 grid-cols-1 md:grid-cols-[minmax(160px,1fr)_minmax(280px,2fr)] items-center">
    <div class="col-span-1 grid grid-rows-[auto_auto] text-center w-full">
        <Image src={portfolioImage} alt="Picture of me" class="profile-image rounded-full w-36 sm:w-44 md:w-48 lg:w-52 mx-auto my-auto row-span-2 shadow-lg shadow-accent border border-secondary-text"/>
        <div class="mt-8 row-span-1 w-full px-4 md:px-0">
            <div class="w-full flex flex-wrap justify-center gap-3 mb-4">
                <SocialMediaLink 
                    socialMediaLink={contact.contactGithub} 
                    icon={<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-brand-github hover:scale-105 transition-all"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" /></svg>} />
                <SocialMediaLink 
                    socialMediaLink={`mailto:${contact.contactEmail}`} 
                    icon={<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-mail"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10" /><path d="M3 7l9 6l9 -6" /></svg>} />
                <SocialMediaLink 
                    socialMediaLink={contact.contactLinkedIn} 
                    icon={<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-brand-linkedin hover:scale-105 transition-all"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M8 11v5" /><path d="M8 8v.01" /><path d="M12 16v-5" /><path d="M16 16v-3a2 2 0 1 0 -4 0" /><path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4l0 -10" /></svg>} />
            </div>
            
            <EmailButton contactEmail={contact.contactEmail}/>
        </div>
    </div>
    <div class="col-span-1 w-full text-center px-4 md:px-0">
        <h1 class="text-2xl sm:text-2xl md:text-3xl lg:text-3xl text-accent italic leading-tight">Luis Villar Roldán</h1>
        <h6 class="text-secondary-text my-2 text-sm leading-relaxed max-w-lg mx-auto">{translations.presentation.subtitle}</h6>
        <p class="text-sm leading-relaxed break-words max-w-lg mx-auto" set:html={contact.contactDescription}></p>
    </div>
</div>

<style>
    .profile-image {
        animation: float 4s ease-in-out infinite;
        box-shadow: var(--profile-shadow-soft);
        transition: box-shadow 0.3s ease;
    }

    @keyframes float {
        0%, 100% {
            transform: translateY(0);
            box-shadow: var(--profile-shadow-soft);
        }

        50% {
            transform: translateY(-18px);
            box-shadow: var(--profile-shadow-strong);
        }
    }
</style>