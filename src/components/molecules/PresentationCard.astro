---
import { Image } from 'astro:assets';
import portfolioImage from '../../assets/fotocurriculum.jpg';
import SocialMediaLink from '../atoms/SocialMediaLink.astro';
import EmailButton from '../atoms/EmailButton.astro';
import contactInfo from '../../data/contact.json'
---

<div class="mx-auto w-2/3 grid grid-cols-3">
    <div class="col-span-1 grid grid-rows-3">
        <Image src={portfolioImage} alt="Picture of me" class="rounded-full w-4/5 mx-auto my-auto row-span-2"/>
        <div class="mt-10 row-span-1">
            <div class="w-full flex justify-around mb-5">
                <SocialMediaLink 
                    socialMediaLink="https://github.com/VRLuis" 
                    icon={<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-brand-github hover:scale-105 transition-all"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" /></svg>} />
                <SocialMediaLink 
                    socialMediaLink="mailto:luisvillarroldan1010@gmail.com" 
                    icon={<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-mail"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10" /><path d="M3 7l9 6l9 -6" /></svg>} />
                <SocialMediaLink 
                    socialMediaLink="https://www.linkedin.com/in/luis-villar-rold%C3%A1n-28826227a/" 
                    icon={<svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-brand-linkedin hover:scale-105 transition-all"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M8 11v5" /><path d="M8 8v.01" /><path d="M12 16v-5" /><path d="M16 16v-3a2 2 0 1 0 -4 0" /><path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4l0 -10" /></svg>} />
            </div>
            
            <EmailButton contactEmail={contactInfo.contactEmail}/>
        </div>
    </div>
    <div class="col-span-2 text-center px-10">
        <h1 class="text-3xl text-accent italic">Luis Villar Roldán</h1>
        <h6 class="text-secondary-text my-5 text-xl">-- FullStack developer --</h6>
        <p class="text-lg">
            <span class="font-bold text-accent">Apasionado de la tecnología</span> desde pequeño, ahora lo convierto en mi profesión. Con una mente <span class="font-bold text-accent">curiosa y resiliente</span>, siempre estoy listo para <span class="font-bold text-accent">aprender</span>, proponer soluciones y llevar ideas a la acción. Me encanta el <span class="font-bold text-accent">desarrollo web</span> y la tecnología en general. Disfruto enfrentando <span class="font-bold text-accent">nuevos desafíos</span>, creando <span class="font-bold text-accent">soluciones funcionales</span> y <span class="font-bold text-accent">aprendiendo constantemente</span>. Valoro el <span class="font-bold text-accent">trabajo en equipo</span> y la oportunidad de crecer con cada proyecto. Siempre estoy abierto a nuevas oportunidades y colaboraciones.
        </p>
    </div>
</div>