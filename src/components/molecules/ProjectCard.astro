---
import ProjectLink from "../atoms/ProjectLink.astro";
import TechBudget from "../atoms/TechBudget.astro";
import ProgressBudget from "../atoms/ProgressBudget.astro";

const { 
    projectName,
    projectDescription,
    projectImage,
    projectLink,
    projectWeb,
    projectTechnologies,
    inProgress,
    translations
} = Astro.props;

const basePath = import.meta.env.BASE_URL || '/';
const projectImageSrc = projectImage?.startsWith('http') || projectImage?.startsWith('//')
    ? projectImage
    : `${basePath}${projectImage}`;
---

<div class="w-full md:w-4/5 bg-card p-5 rounded-lg shadow-lg hover:shadow-xl transition-all grid-span-1 shadow-secondary-accent mx-auto my-2">
    <h1 class="text-2xl text-center font-bold mb-5">{ projectName }</h1>
    <img src={projectImageSrc} alt={ projectName } class="w-100 mx-auto my-5 rounded-lg"/>

    <div class="w-full flex justify-center my-5">
        { inProgress ? <ProgressBudget progressText={translations.buttons.progress}/> : null }
    </div>

    { 
        projectWeb != "" ? 
            <ProjectLink projectLink={projectWeb} linkName={translations.buttons.webLink} linkIcon={<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-world-www"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M19.5 7a9 9 0 0 0 -7.5 -4a8.991 8.991 0 0 0 -7.484 4" /><path d="M11.5 3a16.989 16.989 0 0 0 -1.826 4" /><path d="M12.5 3a16.989 16.989 0 0 1 1.828 4" /><path d="M19.5 17a9 9 0 0 1 -7.5 4a8.991 8.991 0 0 1 -7.484 -4" /><path d="M11.5 21a16.989 16.989 0 0 1 -1.826 -4" /><path d="M12.5 21a16.989 16.989 0 0 0 1.828 -4" /><path d="M2 10l1 4l1.5 -4l1.5 4l1 -4" /><path d="M17 10l1 4l1.5 -4l1.5 4l1 -4" /><path d="M9.5 10l1 4l1.5 -4l1.5 4l1 -4" /></svg>} /> 
        : 
            null 
    }
    
    {
        projectLink != "" ?
            <ProjectLink projectLink={projectLink} linkName={translations.buttons.sourceLink} linkIcon={<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-link"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M9 15l6 -6" /><path d="M11 6l.463 -.536a5 5 0 0 1 7.071 7.072l-.534 .464" /><path d="M13 18l-.397 .534a5.068 5.068 0 0 1 -7.127 0a4.972 4.972 0 0 1 0 -7.071l.524 -.463" /></svg>} />
        :
            null
    }
     

    <h2 class="text-lg font-semibold text-secondary-text">{ projectDescription }</h2>

    <div class="flex flex-wrap gap-2 mt-5">
        { projectTechnologies.map((tech: string) => (
            <TechBudget tech={tech}/>
        )) }   
    </div>
</div>