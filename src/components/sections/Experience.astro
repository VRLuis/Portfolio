---
import SectionHeader from "../atoms/SectionHeader.astro";
import ExperienceList from "../organisms/ExperienceList.astro";
import FormationList from "../organisms/FormationList.astro";
const { translations, experienceData, formationData } = Astro.props;
---

<section id="experience" class="w-7/10 mx-auto text-main-text mt-20">
    <SectionHeader 
        sectionTitle={translations.sections.experienceTitle}
        sectionIcon={<svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-file-cv"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M14 3v4a1 1 0 0 0 1 1h4" /><path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2" /><path d="M11 12.5a1.5 1.5 0 0 0 -3 0v3a1.5 1.5 0 0 0 3 0" /><path d="M13 11l1.5 6l1.5 -6" /></svg>}
    />
    <div class="grid grid-cols-5 mt-10">
        <div class="col-span-3 px-10 border-r-1">
            <div class="flex gap-5 items-center w-full justify-center bg-card py-2 rounded-xl">
                <h1 class="text-2xl font-bold">{translations.nav.experience}</h1>
                <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-briefcase-2"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M3 9a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v9a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-9" /><path d="M8 7v-2a2 2 0 0 1 2 -2h4a2 2 0 0 1 2 2v2" /></svg>
            </div>
            <ExperienceList experiences={experienceData} translations={translations} />
        </div>
        <div class="col-span-2 px-10">
            <div class="flex gap-5 items-center w-full justify-center bg-card py-2 rounded-xl">
                <h1 class="text-2xl font-bold">{translations.sections.formationTitle}</h1>
                <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-school"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M22 9l-10 -4l-10 4l10 4l10 -4v6" /><path d="M6 10.6v5.4a6 3 0 0 0 12 0v-5.4" /></svg>
            </div>
            <FormationList formations={formationData} />
        </div>
    </div>
</section>