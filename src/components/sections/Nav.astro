---
import '../../styles/global.css';
import NavLink from '../atoms/NavLink.astro';
const { nav, lang } = Astro.props;
const basePath = import.meta.env.BASE_URL || '/';
const normalizedBasePath = basePath.endsWith('/') ? basePath : `${basePath}/`;
---

<nav class="bg-card text-main-text mt-0 px-4 sticky top-0 w-full md:w-7/10 mx-auto rounded-xl">
    <div class="relative flex flex-col gap-3 md:flex-row md:justify-between md:items-center w-full md:w-3/4 mx-auto">
        <input id="nav-toggle" type="checkbox" class="peer hidden" />

        <div class="flex items-center justify-between w-full">
            <div class="flex items-center gap-2">
                <span class="text-base font-semibold md:hidden">Menu</span>
            </div>

            <label for="nav-toggle" class="md:hidden inline-flex items-center justify-center rounded-lg border border-border px-3 py-2 text-sm font-medium hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-primary transition-transform duration-200 peer-checked:rotate-90">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 6h16" />
                    <path d="M4 12h16" />
                    <path d="M4 18h16" />
                </svg>
            </label>

            <div class="flex flex-wrap justify-center transition-all overflow-x-hidden">
                <NavLink navLink="about" navTitle={nav.about} />
                <NavLink navLink="experience" navTitle={nav.experience} />
                <NavLink navLink="projects" navTitle={nav.projects} />
                <NavLink navLink="tech" navTitle={nav.tech} />
                <NavLink navLink="learning" navTitle={nav.learning} />
                <NavLink navLink="certificates" navTitle={nav.certificates} />
            </div>
        </div>

        <div class="mobile-menu flex flex-col gap-3 px-2 overflow-hidden max-h-0 opacity-0 transition-all duration-300 ease-in-out md:hidden peer-checked:max-h-96 peer-checked:opacity-100">
            <NavLink navLink="about" navTitle={nav.about} />
            <NavLink navLink="experience" navTitle={nav.experience} />
            <NavLink navLink="projects" navTitle={nav.projects} />
            <NavLink navLink="tech" navTitle={nav.tech} />
            <NavLink navLink="learning" navTitle={nav.learning} />
            <NavLink navLink="certificates" navTitle={nav.certificates} />
        </div>

        <div class="flex justify-center gap-3 text-sm">
            <a href={`${normalizedBasePath}es`} class={lang === 'es' ? 'font-bold underline' : 'hover:underline'}>ES</a>
            <a href={normalizedBasePath} class={lang === 'en' ? 'font-bold underline' : 'hover:underline'}>EN</a>
        </div>
    </div>
</nav>