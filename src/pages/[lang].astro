---
import Nav from '../components/sections/Nav.astro';
import Layout from '../layouts/Layout.astro';
import Header from '../components/sections/Header.astro';
import Experience from '../components/sections/Experience.astro';
import Learning from '../components/sections/Learning.astro';
import Projects from '../components/sections/Projects.astro';
import Certificates from '../components/sections/Certificates.astro';

export async function getStaticPaths() {
    return [
        { params: { lang: 'es' } },
        { params: { lang: 'en' } }
    ];
}

const { lang } = Astro.params;
const locale = lang === 'en' ? 'en' : 'es';

const translations = await import(`../data/i18n/${locale}.json`);
const experienceData = await import(`../data/${locale}/experience.json`);
const formationData = await import(`../data/${locale}/formation.json`);
const learningData = await import(`../data/${locale}/learning.json`);
const projectsData = await import(`../data/${locale}/projects.json`);
const certificatesData = await import(`../data/${locale}/certificates.json`);
const contactData = await import(`../data/${locale}/contact.json`);
---

<Layout lang={lang} pageTitle={translations.default.pageTitle}>
    <Header translations={translations.default} contact={contactData.default} />
    <Nav translations={translations.default} lang={lang} nav={translations.default.nav} />
    <Experience translations={translations.default} experienceData={experienceData.default} formationData={formationData.default} />
    <Projects translations={translations.default} projects={projectsData.default} />
    <Learning translations={translations.default} learningData={learningData.default} />
    <Certificates translations={translations.default} certificates={certificatesData.default} />
</Layout>
